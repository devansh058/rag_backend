# =========================================================
# rag_backend — environment variables (copy to `.env`)
# =========================================================

# --- Django ---
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true

# --- PostgreSQL ---
POSTGRES_DB=rag_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# POSTGRES_SSLMODE=require

# --- Celery / Redis ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# Run tasks inline (no worker / Redis needed) for local dev:
CELERY_TASK_ALWAYS_EAGER=false

# --- Vector store ---
# Vectors are stored inside Postgres via pgvector — no extra service required.

# --- OCR (Tesseract) ---
# Default: script auto-detection (OSD) chooses language packs per page.
# Install packs: `brew install tesseract-lang` then `tesseract --list-langs`.
TESSERACT_SCRIPT_DETECTION=true
# Add English when script is non-Latin (mixed business PDFs)
TESSERACT_APPEND_ENG=true
# Leave unset for auto. Set e.g. TESSERACT_LANG=eng+deu to force languages (skips OSD).
# TESSERACT_LANG=
# When text layer exists but one language is only in images/vectors:
# PDF_OCR_SUPPLEMENT_TEXT_LAYER=false

# --- Celery prefork + PyTorch MPS on macOS → SIGABRT; use cpu ---
EMBEDDING_DEVICE=cpu
# TORCH_NUM_THREADS=1

# --- Gemini ---
# Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Longer answers (token budget; model may still stop earlier)
GEMINI_MAX_OUTPUT_TOKENS=2048
