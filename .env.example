# =========================================================
# rag_backend — environment variables (copy to `.env`)
# =========================================================

# --- Django ---
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true

# --- PostgreSQL ---
POSTGRES_DB=rag_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# POSTGRES_SSLMODE=require

# --- Celery / Redis ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# Run tasks inline (no worker / Redis needed) for local dev:
CELERY_TASK_ALWAYS_EAGER=false

# --- Vector store ---
# Vectors are stored inside Postgres via pgvector — no extra service required.

# --- Gemini ---
# Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
